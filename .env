# Django Core Settings
DJANGO_ENV=local
DJANGO_SECRET_KEY='your_very_strong_and_random_secret_key_here' # Rất quan trọng, hãy tạo một chuỗi ngẫu nhiên và dài

# PostgreSQL Database Settings
POSTGRES_DB=clinic_db # Tên database bạn muốn dùng/đã tạo trong pgAdmin4
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123
POSTGRES_HOST=localhost # Hoặc 127.0.0.1 nếu database chạy trên máy bạn
POSTGRES_PORT=5432 # Cổng mặc định của PostgreSQL

# AWS S3 Settings (có thể để trống nếu chưa dùng ngay)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET_NAME=